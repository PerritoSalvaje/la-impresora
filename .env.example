# ─── Analytics ─────────────────────────────────────────────────────────
NEXT_PUBLIC_AMPLITUDE_API_KEY=tu_api_key_amplitude

# ─── Newsletter (Beehiiv) ──────────────────────────────────────────────
# Sin estas keys, /api/subscribe entra en modo fallback (no pierde emails).
# Crear cuenta gratis en https://beehiiv.com → Settings → Integrations → API
BEEHIIV_API_KEY=
BEEHIIV_PUB_ID=

# Webhook opcional para no perder emails si Beehiiv no está conectado.
# Apunta a un canal Telegram, Slack, o un Google Sheet via Apps Script.
SUBSCRIBE_FALLBACK_WEBHOOK=

# ─── Cobros (LemonSqueezy — micro-productos, libros, packs) ────────────
# Sign up: https://lemonsqueezy.com — 5% fee + Merchant of Record (te declara IVA UE/US)
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# ─── Cobros (Hotmart — curso Academy, Premium membresía LATAM) ─────────
# Mejor para AR/MX/CO/CL/PE: cuotas, OXXO, PIX, MercadoPago nativos
HOTMART_HOTTOK=
HOTMART_CLIENT_ID=
HOTMART_CLIENT_SECRET=

# ─── Telegram (bot que verifica pago y agrega a comunidad Premium) ─────
# @BotFather en Telegram → /newbot → nombre del bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_PREMIUM_CHAT_ID=

# ─── Stripe (sólo backup para sponsors B2B con factura USD) ────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
